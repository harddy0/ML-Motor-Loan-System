# ============================================================
# ML Motor Loan System - Environment Variables Example
# ============================================================
# Copy this file to .env and fill in your actual values.
# This file IS committed to Git — do not put real credentials here.
# ============================================================

# --- Primary Database ---
DB_HOST=localhost
DB_NAME=motorcycle_loan_db
DB_USER=your_db_user
DB_PASS=your_db_password

# --- Secondary Database ---
DB2_HOST=localhost
DB2_NAME=masterdata
DB2_USER=your_db_user
DB2_PASS=your_db_password

# --- Application ---
BASE_URL=http://localhost/ML-Motor-Loan-System